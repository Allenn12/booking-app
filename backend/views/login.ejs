<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="./assets/css/style.css">
    <title>Document</title>
</head>
<body>
    <div id="toastContainer"></div>
    <div class="login" id="loginPage">
        <form id="loginForm">
            <label for="email">Unesite email</label>
            <input type="email" name="email" pattern="^([a-zA-Z0-9_\-\.\+]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$" required />
            <label for="password">Enter your password</label>
            <input type="password" name="password" class="login-input" required>
            <button type="submit" class="button" id="btnLogin">Login</button>
            <p>Not login yet? <a href="/register">Register</a></p>
        </form>
    </div>


    <script src="/main.js"></script>
    <script src="/login.js"></script>
</body>
</html>